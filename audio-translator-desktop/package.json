{
  "name": "audio-translator-desktop",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron . --no-sandbox",
    "prebuild": "bash scripts/prebuild.sh",
    "build": "npm run prebuild && electron-builder",
    "build:mac": "npm run prebuild && electron-builder --mac",
    "postinstall": "cd ../audio-translator-proxy && npm install"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "实时音频翻译桌面应用",
  "build": {
    "appId": "com.bytedance.audio-translator-desktop",
    "productName": "实时翻译",
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ]
    },
    "extraResources": [
      {
        "from": "../audio-translator-proxy",
        "to": "audio-translator-proxy",
        "filter": ["**/*", "!node_modules/.cache"]
      },
      {
        "from": "scripts/create-aggregate-device",
        "to": "audio-tools/create-aggregate-device"
      },
      {
        "from": "scripts/SwitchAudioSource",
        "to": "audio-tools/SwitchAudioSource"
      },
      {
        "from": "scripts/blackhole-2ch.pkg",
        "to": "audio-tools/blackhole-2ch.pkg"
      }
    ],
    "files": [
      "main.js",
      "index.html",
      "renderer.js",
      "floating.html",
      "floating.js",
      "config.json",
      "node_modules/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^41.7.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "ws": "^8.20.1"
  }
}
